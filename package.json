{
  "name": "@workflowfiesta/cli",
  "version": "0.0.1",
  "description": "WorkflowFiesta CLI - Terminal interface for WorkflowFiesta AI agents",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "wf": "./bin/wf.cjs",
    "workflowfiesta": "./bin/wf.cjs"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun run scripts/build.ts",
    "publish": "bun run scripts/publish.ts",
    "start": "bun run src/index.tsx",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.4.3",
    "@opentui/react": "^0.4.3",
    "commander": "^15.0.0",
    "open": "^11.0.0",
    "react": "^19.2.6"
  },
  "keywords": [
    "workflowfiesta",
    "cli",
    "ai",
    "agents",
    "workflow",
    "automation"
  ],
  "license": "SEE LICENSE IN LICENSE"
}
